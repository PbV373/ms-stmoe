{
  "dataset": "nanhai",
  "data_root": ".",
  "input_window": 30,
  "horizon": 15,
  "batch_size": 16,
  "epochs": 200,
  "lr": 0.001,
  "weight_decay": 0.0001,
  "dim": 64,
  "depth": 2,
  "moe_depth": 1,
  "num_experts": 6,
  "gating_top_n": 4,
  "router_noise_mult": 0.7,
  "balance_loss_coef": 0.0003,
  "router_z_loss_coef": 0.001,
  "moe_residual_alpha": 0.3,
  "moe_warmup_epochs": 10,
  "moe_warmup_start_scale": 0.0,
  "moe_warmup_disable_router_noise": false,
  "dropout": 0.0,
  "graph_k_neighbors": 6,
  "spatial_hops": 1,
  "temporal_kernel_size": [3, 7, 9],
  "temporal_dilations": [1, 2, 4],
  "temporal_scale_fusion": "concat",
  "no_st_aware_router": false,
  "num_workers": 0,
  "checkpoint_dir": "checkpoints",
  "prediction_dir": "prediction_results",
  "patience": 10,
  "seed": 42,
  "value_transform": "log1p",
  "seasonal_features": "dayofyear",
  "loss": "huber",
  "huber_delta": 1.0,
  "horizon_loss_end_weight": 1,
  "no_save": false,
  "no_save_predictions": false,
  "smoke_test": false,
  "no_moe": false,
  "no_graph_conv": false,
  "no_seasonal_encoding": false,
  "no_multiscale_tcn": false
}
